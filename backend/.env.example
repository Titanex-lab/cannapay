# ── Required ────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/database"
JWT_SECRET="your-secure-random-string-at-least-32-chars"

# ── Optional with defaults ──────────────────────────────────────────
PORT=3001
NODE_ENV=production
CORS_ORIGIN="https://your-frontend-domain.vercel.app"
CURRENCY=ZAR
CURRENCY_SYMBOL=R
TAX_RATE_STANDARD=0.15
TAX_RATE_EXCISE_FLOWER=0.15
TAX_RATE_EXCISE_EDIBLE=0.15
TAX_RATE_EXCISE_CONCENTRATE=0.15
MANAGER_APPROVAL_VOID_THRESHOLD=500
MANAGER_APPROVAL_ADJUSTMENT_THRESHOLD=1000
BCRYPT_ROUNDS=12

# ── Email receipts (Resend) ──────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_placeholder

# ── Telegram bot ─────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=placeholder

# ── WhatsApp Cloud API (Meta) ────────────────────────────────────────
# From Meta Business Suite → WhatsApp → API Setup
WHATSAPP_API_KEY=placeholder
WHATSAPP_PHONE_NUMBER_ID=placeholder
WHATSAPP_BUSINESS_ACCOUNT_ID=placeholder
