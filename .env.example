# Database
DATABASE_URL="postgresql://a1@localhost:5432/dispensary_pos"

# Auth
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="8h"

# Server
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# Currency
CURRENCY=ZAR
CURRENCY_SYMBOL=R

# Tax (VAT default for South Africa)
TAX_RATE_STANDARD=0.15
TAX_RATE_EXCISE_FLOWER=0.15
TAX_RATE_EXCISE_EDIBLE=0.15
TAX_RATE_EXCISE_CONCENTRATE=0.15

# Thresholds
MANAGER_APPROVAL_VOID_THRESHOLD=500
MANAGER_APPROVAL_ADJUSTMENT_THRESHOLD=1000
